# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Anthropic (Claude API for AI advisor + document extraction)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google OAuth (for Gmail integration)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=https://your-app.vercel.app/api/auth/google/callback

# Resend (for email sending — daily reports, reminders)
RESEND_API_KEY=re_your-key-here
RESEND_FROM_EMAIL=onboarding@resend.dev

# Microsoft OAuth (for Outlook / Hotmail invoice scanning)
# Register at: https://portal.azure.com → App registrations → New registration
# Redirect URI: https://your-app.vercel.app/api/auth/outlook/callback
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_CLIENT_SECRET=your-azure-app-client-secret
MICROSOFT_REDIRECT_URI=https://your-app.vercel.app/api/auth/outlook/callback

# Cron job security
CRON_SECRET=generate-a-random-string-here-32-chars-min

# App URL
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
